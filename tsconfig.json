{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts", "raycast-env.d.ts"],
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "commonjs",
    "target": "ES2023",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "@raycast/api", "vitest/globals"]
  }
}
